<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo.controller.SignUpController"
            prefWidth="360" prefHeight="240"
            style="-fx-background-color: #C8E6E2;">

    <!-- Khai báo ToggleGroup đúng vị trí -->
    <fx:define>
        <ToggleGroup fx:id="roleGroup"/>
    </fx:define>

    <VBox alignment="CENTER" spacing="15"
          AnchorPane.topAnchor="25.0" AnchorPane.leftAnchor="300.0"
          AnchorPane.rightAnchor="300.0" AnchorPane.bottomAnchor="25.0"
          style="-fx-background-color: #9ED5D1; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.25), 8, 0, 0, 3);">

        <!-- Tiêu đề -->
        <Label text="ĐĂNG KÝ TÀI KHOẢN"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #105F68;"/>

        <!-- Ô nhập tài khoản -->
        <TextField fx:id="txtUsername" promptText="Tên đăng nhập"
                   prefWidth="150"
                   style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #9ED5D1; -fx-border-width: 1;"/>

        <!-- Ô nhập mật khẩu -->
        <PasswordField fx:id="txtPassword" promptText="Mật khẩu"
                       prefWidth="150"
                       style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #9ED5D1; -fx-border-width: 1;"/>

        <!-- Nhóm chọn vai trò -->
        <HBox alignment="CENTER" spacing="20">
            <children>
                <RadioButton fx:id="rdoBuyer" text="Người mua" toggleGroup="${roleGroup}" />
                <RadioButton fx:id="rdoSeller" text="Người bán" toggleGroup="${roleGroup}" />
            </children>
        </HBox>

        <!-- Khu vực chứa nút -->
        <HBox alignment="CENTER" spacing="10">
            <Button text="Đăng Ký" onAction="#handleSubmit"
                    fx:id="btnSignUp"
                    prefWidth="90"
                    style="-fx-background-color: #3A9295; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"/>

            <Button text="Back" onAction="#handleBack"
                    fx:id="btnBack"
                    prefWidth="90"
                    style="-fx-background-color: #3A9295; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"/>
        </HBox>

        <!-- Label hiển thị thông báo -->
        <Label fx:id="lblStatus" textFill="red"
               style="-fx-font-size: 12px;"/>

    </VBox>
</AnchorPane>
