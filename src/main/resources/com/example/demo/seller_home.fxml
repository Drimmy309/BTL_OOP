<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo.controller.SellerHomeController"
            prefWidth="900" prefHeight="600">

    <!-- Sidebar bên trái -->
    <left>
        <VBox spacing="10" style="-fx-background-color: #2c3e50;" prefWidth="200">
            <children>
                <Separator style="-fx-background-color: #ecf0f1;"/>

                <!-- Các nút điều hướng -->
                <Button fx:id="btnProductList" text="Quản lý sản phẩm"
                        prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-alignment: CENTER_LEFT"
                        onAction="#handleShowProductList"/>

                <Button fx:id="btnOrders" text="Đơn hàng đã bán"
                        prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-alignment: CENTER_LEFT"
                        onAction="#handleShowOrders"/>

                <Button fx:id="btnRevenue" text="Thống kê doanh thu"
                        prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-alignment: CENTER_LEFT"
                        onAction="#handleShowRevenue"/>

                <Pane fx:id="spacer" VBox.vgrow="ALWAYS"/>

                <!-- Nút đăng xuất -->
                <Button fx:id="btnLogout" text="Logout"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-alignment: CENTER;"
                        onAction="#handleLogout"/>
            </children>
        </VBox>
    </left>

    <!-- Nội dung chính -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1;">
            <children>
                <VBox alignment="CENTER" spacing="20">
                    <Label text="Trang Quản Lý Sản Phẩm" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Xin chào, Seller!" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>
