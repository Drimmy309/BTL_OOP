<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo.controller.SellerHomeController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color: #C8E6E2;">

    <!-- Sidebar bên trái -->
    <left>
        <VBox spacing="10" style="-fx-background-color: #3A9295;" prefWidth="200">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <children>
                <Label text="Seller Dashboard"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"
                       alignment="CENTER"
                       maxWidth="200"/>
                <Separator style="-fx-background-color: #9ED5D1;"/>

                <!-- Các nút điều hướng -->
                <Button fx:id="btnProductList" text="Quản lý sản phẩm"
                        prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-alignment: CENTER_LEFT;"
                        onAction="#handleShowProductList"/>

                <Button fx:id="btnOrders" text="Đơn hàng đã bán"
                        prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-alignment: CENTER_LEFT;"
                        onAction="#handleShowOrders"/>

                <Button fx:id="btnRevenue" text="Thống kê doanh thu"
                        prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-alignment: CENTER_LEFT;"
                        onAction="#handleShowRevenue"/>

                <Pane fx:id="spacer" VBox.vgrow="ALWAYS"/>

                <!-- Nút đăng xuất -->
                <Button fx:id="btnLogout" text="Logout"
                        style="-fx-background-color: red; -fx-text-fill: white; -fx-font-weight: bold; -fx-alignment: CENTER;"
                        onAction="#handleLogout"/>
            </children>
        </VBox>
    </left>

    <!-- Nội dung chính -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #9ED5D1;">
            <children>
                <VBox alignment="CENTER" spacing="20">
                    <Label text="Trang Quản Lý Sản Phẩm"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #105F68;"/>
                    <Label text="Xin chào, Seller!"
                           style="-fx-font-size: 16px; -fx-text-fill: #3A9295;"/>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>
