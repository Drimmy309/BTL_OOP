<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo.controller.LoginController"
            prefWidth="400" prefHeight="250"
            style="-fx-background-color: #f8f9fa;">

    <VBox alignment="CENTER" spacing="15" AnchorPane.topAnchor="30.0" AnchorPane.leftAnchor="50.0"
          AnchorPane.rightAnchor="50.0" AnchorPane.bottomAnchor="30.0">

        <Label text="Đăng nhập hệ thống"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <TextField fx:id="txtUsername" promptText="Tên đăng nhập"
                   prefWidth="250" />

        <TextField fx:id="txtPassword" promptText="Mật khẩu"
                   prefWidth="250" />

        <Button text="Đăng nhập" onAction="#handleLogin"
                prefWidth="120"
                fx:id="btnLogin"
                style="-fx-background-color: #0078d7; -fx-text-fill: white;"/>

        <Label fx:id="lblStatus" textFill="red"/>

    </VBox>

</AnchorPane>
